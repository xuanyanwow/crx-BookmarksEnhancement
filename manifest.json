{
  "manifest_version": 3,
  "name": "收藏夹管理增强",
  "version": "1.0.0",
  "description": "增强管理浏览器收藏夹，支持拖放，通用排序、自动分类管理和导入导出功能。提供直观的可视化界面，让收藏夹管理更高效、更智能。",
  "author": "EdgeFavorites Team",
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "history",
    "tabs",
    "notifications",
    "contextMenus"
  ],
  "action": {
    "default_title": "收藏夹管理增强",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles/*",
        "scripts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx"
}